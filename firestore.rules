rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures user profiles, enforcing owner-only access.
     * @path /users/{userId}
     * @allow (create) User with auth.uid == userId can create their profile.
     * @allow (get, update, delete) User with auth.uid == userId can access and modify their profile.
     * @deny (create, get, update, delete) User with auth.uid != userId cannot access or modify another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not allowed.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures production records under each user, enforcing owner-only access.
     * @path /users/{userId}/productions/{productionId}
     * @allow (create) User with auth.uid == userId can create production records under their profile.
     * @allow (get, list, update, delete) User with auth.uid == userId can access and modify their production records.
     * @deny (create, get, list, update, delete) User with auth.uid != userId cannot access or modify another user's production records.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/productions/{productionId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures product listings under each production record, enforcing owner-only access.
     * @path /users/{userId}/productions/{productionId}/products/{productId}
     * @allow (create) User with auth.uid == userId can create product listings under their production records.
     * @allow (get, list, update, delete) User with auth.uid == userId can access and modify their product listings.
     * @deny (create, get, list, update, delete) User with auth.uid != userId cannot access or modify another user's product listings.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/productions/{productionId}/products/{productId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn();
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secures offers made on products, enforcing authentication for creation.
     * @path /products/{productId}/offers/{offerId}
     * @allow (create) Authenticated users can create offers, ensuring productId matches the document ID.
     * @allow (get, list) Anyone can view offers.
     * @deny (update, delete) Only the offer creator can update or delete offers (not implemented in this prototype).
     * @principle Requires authentication for writes and validates relational integrity.
     */
    match /products/{productId}/offers/{offerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Secures contract agreements between producers and buyers.
     * @path /contracts/{contractId}
     * @allow (get, list) Anyone can read the contract.
     * @deny (create, update, delete) Only authenticated users can create contracts.
     */
    match /contracts/{contractId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Secures messages exchanged between users.
     * @path /messages/{messageId}
     * @allow (create) Authenticated users can create messages, ensuring senderId and receiverId are valid.
     * @allow (get, list) Anyone can read the message.
     * @deny (update, delete) Only the message sender can update or delete the message.
     * @principle Requires authentication for writes and validates sender and receiver relationships.
     */
    match /messages/{messageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn(); // TODO: Add sender/receiver validation once requirements are specified
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Secures notifications for each user, enforcing owner-only access.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow (create) User with auth.uid == userId can create notifications under their profile.
     * @allow (get, list, update, delete) User with auth.uid == userId can access and modify their notifications.
     * @deny (create, get, list, update, delete) User with auth.uid != userId cannot access or modify another user's notifications.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/notifications/{notificationId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}