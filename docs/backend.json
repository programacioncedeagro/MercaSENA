{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the AgroFuturos Conecta platform, either a producer, a buyer, or an administrator.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "role": {
          "type": "string",
          "description": "The user's role within the platform (e.g., producer, buyer, admin)."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number, used for authentication."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address (optional).",
          "format": "email"
        },
        "address": {
          "type": "string",
          "description": "The user's physical address."
        },
        "location": {
          "type": "string",
          "description": "The user's geographic location (e.g., coordinates)."
        }
      },
      "required": [
        "id",
        "role",
        "name",
        "email"
      ]
    },
    "Production": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Production",
      "type": "object",
      "description": "Represents a farmer's production record, tracking all stages from planning to post-harvest.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Production entity."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to User (the producer)."
        },
        "name": {
          "type": "string",
          "description": "Name of the product being produced (e.g. 'Tomate Saladette')."
        },
        "type": {
          "type": "string",
          "description": "The type of production (e.g., Agrícola, Pecuario)."
        },
        "location": {
          "type": "string",
          "description": "Location of the production."
        },
        "area": {
          "type": "number",
          "description": "The area of land used for production (e.g., in hectares) or number of animals."
        },
        "plantingDate": {
          "type": "string",
          "description": "The date when production started.",
          "format": "date"
        },
        "currentState": {
          "type": "string",
          "description": "The current state of the production (e.g., planting, growth, harvest)."
        },
        "progressPercentage": {
          "type": "number",
          "description": "The percentage of progress completed."
        },
        "estimatedHarvestDate": {
          "type": "string",
          "description": "The estimated date of harvest.",
          "format": "date"
        }
      },
      "required": [
        "id",
        "producerId",
        "name",
        "type",
        "location",
        "area",
        "plantingDate",
        "estimatedHarvestDate"
      ]
    },
    "Offer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Offer",
      "type": "object",
      "description": "Represents an offer made by a buyer for a product listed on the AgroFuturos Conecta platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Offer entity."
        },
        "buyerId": {
          "type": "string",
          "description": "Reference to User (the buyer)."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to User (the producer)."
        },
        "productId": {
          "type": "string",
          "description": "Reference to Production document."
        },
        "amount": {
          "type": "number",
          "description": "The quantity of the product being offered."
        },
        "pricePerUnit": {
          "type": "number",
          "description": "The price per unit offered by the buyer."
        },
        "deliveryDate": {
          "type": "string",
          "description": "The desired delivery date specified by the buyer.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current status of the offer (e.g., pendiente, aceptada, rechazada)."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        }
      },
      "required": [
        "id",
        "buyerId",
        "producerId",
        "productId",
        "amount",
        "pricePerUnit",
        "deliveryDate",
        "status",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "collections": [
      {
        "path": "/users/{userId}",
        "schema": "User",
        "description": "Stores user profiles including their role."
      },
      {
        "path": "/users/{userId}/productions/{productionId}",
        "schema": "Production",
        "description": "Subcollection storing production records for each user."
      },
      {
        "path": "/offers/{offerId}",
        "schema": "Offer",
        "description": "Root collection for all offers. Contains producerId and buyerId for easy querying."
      }
    ]
  }
}